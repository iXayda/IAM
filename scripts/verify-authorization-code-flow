#!/usr/bin/env bash

set -euo pipefail

readonly TENANT_ID="00000000-0000-0000-0000-000000000001"
readonly USER_ID="00000000-0000-0000-0000-000000000101"
readonly CLIENT_ID="00000000-0000-0000-0000-000000000102"
readonly CLIENT_IDENTIFIER="release-check-client"
readonly SERVICE_CLIENT_ID="00000000-0000-0000-0000-000000000103"
readonly SERVICE_CLIENT_IDENTIFIER="release-check-service-client"
readonly USERNAME="release-check-user"
readonly PASSWORD="password"
readonly ENCODED_PASSWORD='{bcrypt}$2a$10$dXJ3SW6G7P50lGmMkkmwe.20cQQubK3.HZWzG3YB1tlRy.fqvM/BG'
readonly CLIENT_SECRET="password"
readonly ENCODED_CLIENT_SECRET="${ENCODED_PASSWORD}"
readonly REDIRECT_URI="https://client.release-check.invalid/callback"
readonly CODE_VERIFIER="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-._~"

base_url="${IAM_VERIFY_BASE_URL:?IAM_VERIFY_BASE_URL is required}"
issuer="${IAM_VERIFY_ISSUER:?IAM_VERIFY_ISSUER is required}"
service_token_audience="${IAM_VERIFY_SERVICE_TOKEN_AUDIENCE:?IAM_VERIFY_SERVICE_TOKEN_AUDIENCE is required}"
scim_base_url="${IAM_VERIFY_SCIM_BASE_URL:?IAM_VERIFY_SCIM_BASE_URL is required}"
postgres_container="${IAM_VERIFY_POSTGRES_CONTAINER:?IAM_VERIFY_POSTGRES_CONTAINER is required}"
db_name="${IAM_DB_NAME:-iam}"
db_username="${IAM_DB_USERNAME:-iam}"
work_dir=""

log() {
	printf '[authorization-smoke] %s\n' "$*"
}

fail() {
	log "ERROR: $*" >&2
	exit 1
}

require_command() {
	command -v "$1" >/dev/null 2>&1 || fail "Required command is unavailable: $1"
}

cleanup() {
	local status=$?
	trap - EXIT
	[[ -z "${work_dir}" ]] || rm -rf -- "${work_dir}"
	exit "${status}"
}

database() {
	docker exec -i "${postgres_container}" psql --no-psqlrc --username "${db_username}" \
		--dbname "${db_name}" --set=ON_ERROR_STOP=1 "$@"
}

header_value() {
	local name=$1
	local file=$2
	awk -v expected="${name}" '
		tolower($1) == tolower(expected ":") {
			sub(/^[^:]*:[[:space:]]*/, "")
			sub(/\r$/, "")
			print
			exit
		}
	' "${file}"
}

html_input_value() {
	local name=$1
	local file=$2
	sed -n "s/.*name=\"${name}\"[^>]*value=\"\([^\"]*\)\".*/\1/p" "${file}" | head -n 1
}

query_parameter() {
	local url=$1
	local name=$2
	local query="${url#*\?}"
	local pair
	[[ "${query}" != "${url}" ]] || return 1
	while [[ -n "${query}" ]]; do
		pair="${query%%&*}"
		if [[ "${pair%%=*}" == "${name}" ]]; then
			printf '%s\n' "${pair#*=}"
			return 0
		fi
		[[ "${query}" == *"&"* ]] || break
		query="${query#*&}"
	done
	return 1
}

decode_jwt_payload() {
	local token=$1
	local payload="${token#*.}"
	payload="${payload%%.*}"
	case $((${#payload} % 4)) in
		2) payload="${payload}==" ;;
		3) payload="${payload}=" ;;
		1) return 1 ;;
	esac
	printf '%s' "${payload}" | tr '_-' '/+' | openssl base64 -d -A
}

seed_fixture() {
	database --set=user_id="${USER_ID}" --set=client_id="${CLIENT_ID}" \
		--set=service_client_id="${SERVICE_CLIENT_ID}" \
		--set=tenant_id="${TENANT_ID}" --set=username="${USERNAME}" \
		--set=encoded_password="${ENCODED_PASSWORD}" --set=client_identifier="${CLIENT_IDENTIFIER}" \
		--set=service_client_identifier="${SERVICE_CLIENT_IDENTIFIER}" \
		--set=encoded_client_secret="${ENCODED_CLIENT_SECRET}" \
		--set=redirect_uri="${REDIRECT_URI}" >/dev/null <<'SQL'
BEGIN;
INSERT INTO users (user_id, tenant_id)
VALUES (:'user_id', :'tenant_id');
INSERT INTO user_login_identifiers
    (tenant_id, user_id, identifier_type, identifier_value, canonical_value)
VALUES
    (:'tenant_id', :'user_id', 'username', :'username', :'username');
INSERT INTO user_password_credentials (tenant_id, user_id, encoded_password)
VALUES (:'tenant_id', :'user_id', :'encoded_password');
INSERT INTO oauth_clients
	    (client_id, tenant_id, client_identifier, display_name, client_type, authentication_method,
	     encoded_client_secret, client_secret_issued_at, client_secret_expires_at,
	     refresh_tokens_enabled, refresh_token_ttl_seconds)
VALUES
	    (:'client_id', :'tenant_id', :'client_identifier', 'Release Check Client',
	     'confidential', 'client_secret_basic', :'encoded_client_secret', now(), now() + interval '90 days',
	     TRUE, 3600);
INSERT INTO oauth_client_redirect_uris (tenant_id, client_id, redirect_uri)
VALUES (:'tenant_id', :'client_id', :'redirect_uri');
INSERT INTO oauth_client_scopes (tenant_id, client_id, scope)
VALUES (:'tenant_id', :'client_id', 'openid'), (:'tenant_id', :'client_id', 'profile');
INSERT INTO oauth_clients
	    (client_id, tenant_id, client_identifier, display_name, client_type, authentication_method,
	     authorization_grant_type, encoded_client_secret, client_secret_issued_at,
	     client_secret_expires_at, access_token_ttl_seconds)
VALUES
	    (:'service_client_id', :'tenant_id', :'service_client_identifier', 'Release Check Service Client',
	     'confidential', 'client_secret_basic', 'client_credentials', :'encoded_client_secret', now(),
	     now() + interval '90 days', 300);
INSERT INTO oauth_client_scopes (tenant_id, client_id, authorization_grant_type, scope)
VALUES
	    (:'tenant_id', :'service_client_id', 'client_credentials', 'scim.read'),
	    (:'tenant_id', :'service_client_id', 'client_credentials', 'scim.write');
COMMIT;
SQL
}

trap cleanup EXIT
require_command curl
require_command docker
require_command jq
require_command openssl
require_command awk
require_command sed
work_dir="$(mktemp -d "${TMPDIR:-/tmp}/iam-authorization-smoke.XXXXXX")"

cookies="${work_dir}/cookies"
headers="${work_dir}/headers"
body="${work_dir}/body"
token_response="${work_dir}/token-response.json"
refresh_response="${work_dir}/refresh-response.json"
userinfo="${work_dir}/userinfo.json"
id_payload="${work_dir}/id-token.json"
service_token_response="${work_dir}/service-token-response.json"
service_token_payload="${work_dir}/service-token.json"
client_state="release-check-state"
nonce="release-check-nonce"
code_challenge="$(printf '%s' "${CODE_VERIFIER}" | openssl dgst -sha256 -binary \
	| openssl base64 -A | tr '+/' '-_' | tr -d '=')"

log "Seeding disposable user and confidential client"
seed_fixture

log "Checking provider metadata and JWK publication"
curl --fail --silent --show-error --max-time 10 "${base_url}/.well-known/openid-configuration" \
	| jq -e --arg issuer "${issuer}" \
		'.issuer == $issuer and .authorization_endpoint == ($issuer + "/oauth2/authorize") and .token_endpoint == ($issuer + "/oauth2/token")' \
	>/dev/null || fail "OpenID Provider metadata is invalid"
curl --fail --silent --show-error --max-time 10 "${base_url}/oauth2/jwks" \
	| jq -e '.keys | length == 1 and .[0].kty == "RSA" and .[0].alg == "RS256" and (.[0].d | not)' \
	>/dev/null || fail "Published JWK set is invalid"

log "Starting Authorization Code request"
status="$(curl --silent --show-error --max-time 10 --output /dev/null --dump-header "${headers}" \
	--cookie-jar "${cookies}" --write-out '%{http_code}' --get "${base_url}/oauth2/authorize" \
	--header 'Accept: text/html' --data-urlencode 'response_type=code' \
	--data-urlencode "client_id=${CLIENT_IDENTIFIER}" --data-urlencode "redirect_uri=${REDIRECT_URI}" \
	--data-urlencode 'scope=openid profile' --data-urlencode "state=${client_state}" \
	--data-urlencode "nonce=${nonce}" --data-urlencode "code_challenge=${code_challenge}" \
	--data-urlencode 'code_challenge_method=S256')"
[[ "${status}" == "302" ]] || fail "Authorization request returned HTTP ${status}"
[[ "$(header_value Location "${headers}")" == */login ]] || fail "Authorization request did not redirect to login"

curl --fail --silent --show-error --max-time 10 --cookie "${cookies}" --cookie-jar "${cookies}" \
	--header 'Accept: text/html' --output "${body}" "${base_url}/login"
csrf="$(html_input_value _csrf "${body}")"
[[ -n "${csrf}" ]] || fail "Login page did not contain a CSRF token"

log "Authenticating the local user"
status="$(curl --silent --show-error --max-time 10 --output /dev/null --dump-header "${headers}" \
	--cookie "${cookies}" --cookie-jar "${cookies}" --write-out '%{http_code}' --request POST \
	--data-urlencode "username=${USERNAME}" --data-urlencode "password=${PASSWORD}" \
	--data-urlencode "_csrf=${csrf}" "${base_url}/login")"
[[ "${status}" == "302" ]] || fail "Login returned HTTP ${status}"
continuation="$(header_value Location "${headers}")"
[[ "${continuation}" == "${issuer}/oauth2/authorize?"* ]] || fail "Login did not return to the fixed issuer"
continuation="${continuation#${issuer}}"

status="$(curl --silent --show-error --max-time 10 --cookie "${cookies}" --cookie-jar "${cookies}" \
	--header 'Accept: text/html' --output /dev/null --dump-header "${headers}" --write-out '%{http_code}' \
	"${base_url}${continuation}")"
[[ "${status}" == "302" ]] || fail "Authorization continuation returned HTTP ${status}"
consent_location="$(header_value Location "${headers}")"
[[ "${consent_location}" == "${issuer}/oauth2/consent?"* ]] || fail "Authorization did not use the fixed issuer consent page"
consent_location="${consent_location#${issuer}}"
curl --fail --silent --show-error --max-time 10 --cookie "${cookies}" --cookie-jar "${cookies}" \
	--header 'Accept: text/html' --output "${body}" "${base_url}${consent_location}"
consent_state="$(html_input_value state "${body}")"
[[ -n "${consent_state}" && "${consent_state}" != "${client_state}" ]] \
	|| fail "Consent page did not contain an independent server state"
grep -q 'name="scope" value="profile"' "${body}" || fail "Consent page did not request the profile scope"

log "Approving consent and receiving the authorization code"
status="$(curl --silent --show-error --max-time 10 --output /dev/null --dump-header "${headers}" \
	--cookie "${cookies}" --cookie-jar "${cookies}" --write-out '%{http_code}' --request POST \
	--data-urlencode "client_id=${CLIENT_IDENTIFIER}" --data-urlencode "state=${consent_state}" \
	--data-urlencode 'scope=profile' "${base_url}/oauth2/authorize")"
[[ "${status}" == "302" ]] || fail "Consent submission returned HTTP ${status}"
client_redirect="$(header_value Location "${headers}")"
[[ "${client_redirect}" == "${REDIRECT_URI}?"* ]] || fail "Consent did not redirect to the registered callback"
code="$(query_parameter "${client_redirect}" code)"
returned_state="$(query_parameter "${client_redirect}" state)"
[[ -n "${code}" && "${returned_state}" == "${client_state}" ]] || fail "Authorization response is incomplete"

log "Checking PKCE failure does not consume the code"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --write-out '%{http_code}' \
	--user "${CLIENT_IDENTIFIER}:${CLIENT_SECRET}" --request POST --data-urlencode 'grant_type=authorization_code' \
	--data-urlencode "code=${code}" \
	--data-urlencode "redirect_uri=${REDIRECT_URI}" --data-urlencode "code_verifier=wrong-${CODE_VERIFIER}" \
	"${base_url}/oauth2/token")"
[[ "${status}" == "400" ]] && jq -e '.error == "invalid_grant"' "${body}" >/dev/null \
	|| fail "Incorrect PKCE verifier was not rejected"

log "Exchanging the code with the correct verifier"
status="$(curl --silent --show-error --max-time 10 --output "${token_response}" --write-out '%{http_code}' \
	--user "${CLIENT_IDENTIFIER}:${CLIENT_SECRET}" --request POST --data-urlencode 'grant_type=authorization_code' \
	--data-urlencode "code=${code}" \
	--data-urlencode "redirect_uri=${REDIRECT_URI}" --data-urlencode "code_verifier=${CODE_VERIFIER}" \
	"${base_url}/oauth2/token")"
[[ "${status}" == "200" ]] || fail "Token exchange returned HTTP ${status}"
jq -e '.token_type == "Bearer" and .expires_in > 0 and (.scope | split(" ") | sort == ["openid", "profile"]) and (.refresh_token | type == "string" and length > 0)' \
	"${token_response}" >/dev/null || fail "Token response is invalid"
access_token="$(jq -er '.access_token' "${token_response}")"
refresh_token="$(jq -er '.refresh_token' "${token_response}")"
id_token="$(jq -er '.id_token' "${token_response}")"
decode_jwt_payload "${id_token}" >"${id_payload}" || fail "ID token payload is not valid base64url"
jq -e --arg issuer "${issuer}" --arg subject "${USER_ID}" --arg audience "${CLIENT_IDENTIFIER}" \
	--arg nonce "${nonce}" \
	'.iss == $issuer and .sub == $subject and (.aud == $audience or .aud == [$audience]) and .nonce == $nonce' \
	"${id_payload}" >/dev/null || fail "ID token claims are invalid"

status="$(curl --silent --show-error --max-time 10 --output "${userinfo}" --write-out '%{http_code}' \
	--header "Authorization: Bearer ${access_token}" "${base_url}/userinfo")"
[[ "${status}" == "200" ]] && jq -e --arg subject "${USER_ID}" '.sub == $subject' "${userinfo}" >/dev/null \
	|| fail "Issued access token was not accepted by UserInfo"

log "Rotating access, refresh, and ID tokens with reduced scope"
status="$(curl --silent --show-error --max-time 10 --output "${refresh_response}" --write-out '%{http_code}' \
	--user "${CLIENT_IDENTIFIER}:${CLIENT_SECRET}" --request POST --data-urlencode 'grant_type=refresh_token' \
	--data-urlencode "refresh_token=${refresh_token}" --data-urlencode 'scope=openid' \
	"${base_url}/oauth2/token")"
[[ "${status}" == "200" ]] || fail "Refresh Token exchange returned HTTP ${status}"
jq -e '.token_type == "Bearer" and .expires_in > 0 and .scope == "openid" and (.refresh_token | type == "string" and length > 0)' \
	"${refresh_response}" >/dev/null || fail "Refresh Token response is invalid"
rotated_access_token="$(jq -er '.access_token' "${refresh_response}")"
rotated_refresh_token="$(jq -er '.refresh_token' "${refresh_response}")"
rotated_id_token="$(jq -er '.id_token' "${refresh_response}")"
[[ "${rotated_access_token}" != "${access_token}" && "${rotated_refresh_token}" != "${refresh_token}" \
	&& "${rotated_id_token}" != "${id_token}" ]] || fail "Refresh Token exchange did not rotate every renewable token"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --write-out '%{http_code}' \
	--header "Authorization: Bearer ${rotated_access_token}" "${base_url}/userinfo")"
[[ "${status}" == "200" ]] || fail "Rotated access token was not accepted by UserInfo"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --write-out '%{http_code}' \
	--header "Authorization: Bearer ${access_token}" "${base_url}/userinfo")"
[[ "${status}" == "401" ]] || fail "Rotated access token left the previous access token active"

log "Rejecting the rotated Refresh Token"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --write-out '%{http_code}' \
	--user "${CLIENT_IDENTIFIER}:${CLIENT_SECRET}" --request POST --data-urlencode 'grant_type=refresh_token' \
	--data-urlencode "refresh_token=${refresh_token}" "${base_url}/oauth2/token")"
[[ "${status}" == "400" ]] && jq -e '.error == "invalid_grant"' "${body}" >/dev/null \
	|| fail "Rotated Refresh Token was not rejected"

log "Continuing rotation with the current Refresh Token"
status="$(curl --silent --show-error --max-time 10 --output "${refresh_response}" --write-out '%{http_code}' \
	--user "${CLIENT_IDENTIFIER}:${CLIENT_SECRET}" --request POST --data-urlencode 'grant_type=refresh_token' \
	--data-urlencode "refresh_token=${rotated_refresh_token}" "${base_url}/oauth2/token")"
[[ "${status}" == "200" ]] || fail "Current Refresh Token was not accepted"
jq -e '.token_type == "Bearer" and (.scope | split(" ") | sort == ["openid", "profile"]) and (.refresh_token | type == "string" and length > 0)' \
	"${refresh_response}" >/dev/null || fail "Continued Refresh Token response is invalid"
current_access_token="$(jq -er '.access_token' "${refresh_response}")"
current_refresh_token="$(jq -er '.refresh_token' "${refresh_response}")"
current_id_token="$(jq -er '.id_token' "${refresh_response}")"
[[ "${current_access_token}" != "${rotated_access_token}" \
	&& "${current_refresh_token}" != "${rotated_refresh_token}" \
	&& "${current_id_token}" != "${rotated_id_token}" ]] || fail "Continued Refresh Token exchange did not rotate every renewable token"

log "Replaying the code and checking current token invalidation"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --write-out '%{http_code}' \
	--user "${CLIENT_IDENTIFIER}:${CLIENT_SECRET}" --request POST --data-urlencode 'grant_type=authorization_code' \
	--data-urlencode "code=${code}" \
	--data-urlencode "redirect_uri=${REDIRECT_URI}" --data-urlencode "code_verifier=${CODE_VERIFIER}" \
	"${base_url}/oauth2/token")"
[[ "${status}" == "400" ]] && jq -e '.error == "invalid_grant"' "${body}" >/dev/null \
	|| fail "Authorization code replay was not rejected"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --write-out '%{http_code}' \
	--header "Authorization: Bearer ${current_access_token}" "${base_url}/userinfo")"
[[ "${status}" == "401" ]] || fail "Replayed authorization left the current access token active"

token_state="$(database --tuples-only --no-align --command "
	SELECT string_agg(token_type || ':' || (invalidated_at IS NOT NULL)::text, ',' ORDER BY token_type)
	FROM oauth_authorization_tokens WHERE client_id = '${CLIENT_ID}'")"
[[ "${token_state}" == "access_token:true,authorization_code:true,id_token:false,refresh_token:true" ]] \
	|| fail "Persisted token state is invalid: ${token_state}"
consent_count="$(database --tuples-only --no-align --command \
	"SELECT count(*) FROM oauth_authorization_consent_authorities WHERE client_id = '${CLIENT_ID}'")"
[[ "${consent_count}" == "2" ]] || fail "Expected two persisted consent authorities"
password_encoding="$(database --tuples-only --no-align --command \
	"SELECT split_part(encoded_password, '}', 1) || '}' FROM user_password_credentials WHERE user_id = '${USER_ID}'")"
[[ "${password_encoding}" == "{pbkdf2@SpringSecurity_v5_8}" ]] \
	|| fail "Legacy password hash was not upgraded during native authentication"

log "Issuing a tenant-bound Client Credentials access token"
status="$(curl --silent --show-error --max-time 10 --output "${service_token_response}" --write-out '%{http_code}' \
	--user "${SERVICE_CLIENT_IDENTIFIER}:${CLIENT_SECRET}" --request POST \
	--data-urlencode 'grant_type=client_credentials' --data-urlencode 'scope=scim.read' \
	--data-urlencode 'tenant_id=00000000-0000-0000-0000-000000000999' \
	--data-urlencode 'audience=https://attacker.release-check.invalid' "${base_url}/oauth2/token")"
[[ "${status}" == "200" ]] || fail "Client Credentials exchange returned HTTP ${status}"
jq -e \
	'.token_type == "Bearer" and .expires_in > 0 and .expires_in <= 300 and .scope == "scim.read"
	 and (.refresh_token | not) and (.id_token | not)' \
	"${service_token_response}" >/dev/null || fail "Client Credentials token response is invalid"
service_access_token="$(jq -er '.access_token' "${service_token_response}")"
decode_jwt_payload "${service_access_token}" >"${service_token_payload}" \
	|| fail "Service access token payload is not valid base64url"
jq -e --arg issuer "${issuer}" --arg subject "${SERVICE_CLIENT_IDENTIFIER}" \
	--arg audience "${service_token_audience}" --arg tenant_id "${TENANT_ID}" \
	'.iss == $issuer and .sub == $subject and (.aud == $audience or .aud == [$audience])
	 and .client_id == $subject and .tenant_id == $tenant_id and .scope == ["scim.read"]' \
	"${service_token_payload}" >/dev/null || fail "Service access token claims are invalid"
service_authorization_count="$(database --tuples-only --no-align --command "
	SELECT count(*)
	FROM oauth_authorizations authorizations
	JOIN oauth_authorization_tokens tokens
	  USING (tenant_id, client_id, authorization_id, authorization_grant_type)
	WHERE authorizations.client_id = '${SERVICE_CLIENT_ID}'
	  AND authorizations.authorization_grant_type = 'client_credentials'
	  AND authorizations.principal_name = '${SERVICE_CLIENT_IDENTIFIER}'
	  AND authorizations.user_id IS NULL
	  AND authorizations.session_id IS NULL
	  AND authorizations.authorization_uri IS NULL
	  AND authorizations.redirect_uri IS NULL
	  AND authorizations.client_state IS NULL
	  AND authorizations.request_parameters = '{}'::jsonb
	  AND tokens.token_type = 'access_token'
	  AND (SELECT count(*) FROM oauth_authorization_tokens service_tokens
	       WHERE service_tokens.client_id = '${SERVICE_CLIENT_ID}') = 1")"
[[ "${service_authorization_count}" == "1" ]] \
	|| fail "Expected one persisted Client Credentials authorization"
service_scope_state="$(database --tuples-only --no-align --command "
	SELECT
	  (SELECT count(*) FROM oauth_authorization_requested_scopes WHERE client_id = '${SERVICE_CLIENT_ID}') || ':' ||
	  (SELECT count(*) FROM oauth_authorization_scopes WHERE client_id = '${SERVICE_CLIENT_ID}') || ':' ||
	  (SELECT count(*) FROM oauth_authorization_token_scopes WHERE client_id = '${SERVICE_CLIENT_ID}')")"
[[ "${service_scope_state}" == "1:1:1" ]] \
	|| fail "Persisted Client Credentials scope state is invalid: ${service_scope_state}"

log "Checking the SCIM resource-server boundary"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --dump-header "${headers}" \
	--write-out '%{http_code}' \
	--header 'Accept: application/scim+json' --header "Authorization: Bearer ${service_access_token}" \
	"${base_url}/scim/v2/Users/${USER_ID}")"
[[ "${status}" == "200" ]] || fail "SCIM read token did not retrieve its tenant user: HTTP ${status}"
scim_user_location="${scim_base_url}/Users/${USER_ID}"
jq -e --arg id "${USER_ID}" --arg username "${USERNAME}" --arg location "${scim_user_location}" \
	'.schemas == ["urn:ietf:params:scim:schemas:core:2.0:User"]
	 and .id == $id and .userName == $username and .active == true
	 and .meta.resourceType == "User" and .meta.location == $location
	 and (has("password") | not)' \
	"${body}" >/dev/null || fail "SCIM user representation is invalid"
[[ "$(header_value Content-Location "${headers}")" == "${scim_user_location}" ]] \
	|| fail "SCIM user Content-Location is invalid"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --dump-header "${headers}" \
	--write-out '%{http_code}' --get \
	--header 'Accept: application/scim+json' --header "Authorization: Bearer ${service_access_token}" \
	--data-urlencode "filter=userName eq \"${USERNAME}\"" --data-urlencode 'count=1' \
	--data-urlencode 'tenant_id=00000000-0000-0000-0000-000000000999' \
	"${base_url}/scim/v2/Users")"
[[ "${status}" == "200" ]] || fail "SCIM read token did not query its tenant directory: HTTP ${status}"
jq -e --arg id "${USER_ID}" --arg username "${USERNAME}" \
	'.schemas == ["urn:ietf:params:scim:api:messages:2.0:ListResponse"]
	 and .totalResults == 1 and .startIndex == 1 and .itemsPerPage == 1
	 and (.Resources | length) == 1
	 and .Resources[0].id == $id and .Resources[0].userName == $username
	 and (.Resources[0] | has("password") | not)' \
	"${body}" >/dev/null || fail "SCIM User collection response is invalid"
[[ "$(header_value Content-Location "${headers}")" == "${scim_base_url}/Users" ]] \
	|| fail "SCIM User collection Content-Location is invalid"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --write-out '%{http_code}' \
	--request POST --header 'Accept: application/scim+json' \
	--header "Authorization: Bearer ${service_access_token}" "${base_url}/scim/v2/Users")"
[[ "${status}" == "403" ]] && jq -e '.status == "403"' "${body}" >/dev/null \
	|| fail "SCIM write request was not rejected for a read-only token"

status="$(curl --silent --show-error --max-time 10 --output "${service_token_response}" --write-out '%{http_code}' \
	--user "${SERVICE_CLIENT_IDENTIFIER}:${CLIENT_SECRET}" --request POST \
	--data-urlencode 'grant_type=client_credentials' --data-urlencode 'scope=scim.write' \
	"${base_url}/oauth2/token")"
[[ "${status}" == "200" ]] || fail "Client Credentials write-token exchange returned HTTP ${status}"
jq -e \
	'.token_type == "Bearer" and .expires_in > 0 and .expires_in <= 300 and .scope == "scim.write"
	 and (.refresh_token | not) and (.id_token | not)' \
	"${service_token_response}" >/dev/null || fail "Client Credentials write-token response is invalid"
service_write_access_token="$(jq -er '.access_token' "${service_token_response}")"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --dump-header "${headers}" \
	--write-out '%{http_code}' --request POST \
	--header 'Accept: application/scim+json' --header 'Content-Type: application/scim+json' \
	--header "Authorization: Bearer ${service_write_access_token}" \
	--data '{"schemas":["urn:ietf:params:scim:schemas:core:2.0:User"],"userName":"release-created-user","active":false}' \
	"${base_url}/scim/v2/Users")"
[[ "${status}" == "201" ]] || fail "SCIM write token did not create a tenant user: HTTP ${status}"
created_scim_user_id="$(jq -er '.id' "${body}")"
created_scim_user_location="${scim_base_url}/Users/${created_scim_user_id}"
jq -e --arg location "${created_scim_user_location}" \
	'.schemas == ["urn:ietf:params:scim:schemas:core:2.0:User"]
	 and .userName == "release-created-user" and .active == false
	 and .meta.resourceType == "User" and .meta.location == $location
	 and (has("password") | not)' \
	"${body}" >/dev/null || fail "Created SCIM User representation is invalid"
[[ "$(header_value Location "${headers}")" == "${created_scim_user_location}" \
	&& "$(header_value Content-Location "${headers}")" == "${created_scim_user_location}" ]] \
	|| fail "Created SCIM User location headers are invalid"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --dump-header "${headers}" \
	--write-out '%{http_code}' --request PUT \
	--header 'Accept: application/scim+json' --header 'Content-Type: application/scim+json' \
	--header "Authorization: Bearer ${service_write_access_token}" \
	--data '{"schemas":["urn:ietf:params:scim:schemas:core:2.0:User"],"userName":"release-replaced-user","displayName":"Release Replaced User","active":true}' \
	"${base_url}/scim/v2/Users/${created_scim_user_id}")"
[[ "${status}" == "200" ]] || fail "SCIM write token did not replace a tenant user: HTTP ${status}"
jq -e --arg id "${created_scim_user_id}" --arg location "${created_scim_user_location}" \
	'.schemas == ["urn:ietf:params:scim:schemas:core:2.0:User"] and .id == $id
	 and .userName == "release-replaced-user" and .displayName == "Release Replaced User" and .active == true
	 and .meta.resourceType == "User" and .meta.location == $location
	 and (.emails | length == 0) and (.phoneNumbers | length == 0) and (has("password") | not)' \
	"${body}" >/dev/null || fail "Replaced SCIM User representation is invalid"
[[ "$(header_value Location "${headers}")" == "${created_scim_user_location}" \
	&& "$(header_value Content-Location "${headers}")" == "${created_scim_user_location}" ]] \
	|| fail "Replaced SCIM User location headers are invalid"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --dump-header "${headers}" \
	--write-out '%{http_code}' --request PATCH \
	--header 'Accept: application/scim+json' --header 'Content-Type: application/scim+json' \
	--header "Authorization: Bearer ${service_write_access_token}" \
	--data '{"schemas":["urn:ietf:params:scim:api:messages:2.0:PatchOp"],"Operations":[{"op":"add","path":"emails","value":{"value":"release@example.com"}},{"op":"replace","path":"emails[VALUE eq \"release@example.com\"].value","value":"release-patched@example.com"},{"op":"add","path":"phoneNumbers","value":{"value":"tel:+15551234567"}},{"op":"remove","path":"phoneNumbers[value eq \"tel:+15551234567\"]"},{"op":"replace","path":"displayName","value":"Release Patched User"},{"op":"replace","path":"name.givenName","value":"Release"},{"op":"replace","path":"active","value":false}]}' \
	"${base_url}/scim/v2/Users/${created_scim_user_id}")"
[[ "${status}" == "200" ]] || fail "SCIM write token did not patch a tenant user: HTTP ${status}"
jq -e --arg id "${created_scim_user_id}" --arg location "${created_scim_user_location}" \
	'.schemas == ["urn:ietf:params:scim:schemas:core:2.0:User"] and .id == $id
	 and .userName == "release-replaced-user" and .displayName == "Release Patched User"
	 and .name.givenName == "Release" and .active == false
	 and .emails == [{"value":"release-patched@example.com"}] and (.phoneNumbers | length) == 0
	 and .meta.resourceType == "User" and .meta.location == $location and (has("password") | not)' \
	"${body}" >/dev/null || fail "Patched SCIM User representation is invalid"
[[ "$(header_value Location "${headers}")" == "${created_scim_user_location}" \
	&& "$(header_value Content-Location "${headers}")" == "${created_scim_user_location}" ]] \
	|| fail "Patched SCIM User location headers are invalid"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --write-out '%{http_code}' \
	--request PATCH --header 'Accept: application/scim+json' \
	--header 'Content-Type: application/scim+json' \
	--header "Authorization: Bearer ${service_write_access_token}" \
	--data '{"schemas":["urn:ietf:params:scim:api:messages:2.0:PatchOp"],"Operations":[{"op":"replace","path":"displayName","value":"Must Not Persist"},{"op":"replace","path":"emails[value eq \"missing@example.com\"].value","value":"also-must-not-persist@example.com"}]}' \
	"${base_url}/scim/v2/Users/${created_scim_user_id}")"
[[ "${status}" == "400" ]] \
	&& jq -e '.status == "400" and .scimType == "noTarget"
		and (.detail | contains("missing@example.com") | not)' "${body}" >/dev/null \
	|| fail "SCIM PATCH noTarget response was invalid"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --write-out '%{http_code}' \
	--header 'Accept: application/scim+json' --header "Authorization: Bearer ${service_access_token}" \
	"${base_url}/scim/v2/Users/${created_scim_user_id}")"
[[ "${status}" == "200" ]] \
	&& jq -e '.userName == "release-replaced-user" and .displayName == "Release Patched User"
		and .name.givenName == "Release" and .active == false
		and .emails == [{"value":"release-patched@example.com"}] and (.phoneNumbers | length) == 0' \
		"${body}" >/dev/null \
	|| fail "Patched SCIM User was not readable through the native service"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --write-out '%{http_code}' \
	--request POST --header 'Accept: application/scim+json' \
	--header "Authorization: Bearer ${service_write_access_token}" "${base_url}/scim/v2/Groups")"
[[ "${status}" == "404" ]] || fail "SCIM write token did not pass the resource-server boundary: HTTP ${status}"

log "Authorization Code + PKCE + OIDC + Refresh Token + Client Credentials flows passed"
