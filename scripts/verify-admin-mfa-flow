#!/usr/bin/env bash

set -euo pipefail

readonly TENANT_ID="00000000-0000-0000-0000-000000000001"
readonly USER_ID="00000000-0000-0000-0000-000000000201"
readonly CLIENT_ID="00000000-0000-0000-0000-000000000202"
readonly CLIENT_IDENTIFIER="release-check-admin-client"
readonly USERNAME="release-check-admin"
readonly PASSWORD="password"
readonly ENCODED_PASSWORD='{bcrypt}$2a$10$dXJ3SW6G7P50lGmMkkmwe.20cQQubK3.HZWzG3YB1tlRy.fqvM/BG'
readonly CLIENT_SECRET="password"
readonly ENCODED_CLIENT_SECRET="${ENCODED_PASSWORD}"
readonly REDIRECT_URI="https://admin-client.release-check.invalid/callback"
readonly CODE_VERIFIER="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-._~"

base_url="${IAM_VERIFY_BASE_URL:?IAM_VERIFY_BASE_URL is required}"
issuer="${IAM_VERIFY_ISSUER:?IAM_VERIFY_ISSUER is required}"
admin_token_audience="${IAM_VERIFY_ADMIN_TOKEN_AUDIENCE:?IAM_VERIFY_ADMIN_TOKEN_AUDIENCE is required}"
postgres_container="${IAM_VERIFY_POSTGRES_CONTAINER:?IAM_VERIFY_POSTGRES_CONTAINER is required}"
db_name="${IAM_DB_NAME:-iam}"
db_username="${IAM_DB_USERNAME:-iam}"
work_dir=""

[[ "${IAM_VERIFY_DISPOSABLE_DATABASE:-}" == "true" ]] \
	|| { printf '[admin-mfa-smoke] ERROR: IAM_VERIFY_DISPOSABLE_DATABASE=true is required\n' >&2; exit 1; }

log() {
	printf '[admin-mfa-smoke] %s\n' "$*"
}

fail() {
	log "ERROR: $*" >&2
	exit 1
}

require_command() {
	command -v "$1" >/dev/null 2>&1 || fail "Required command is unavailable: $1"
}

cleanup() {
	local status=$?
	trap - EXIT
	[[ -z "${work_dir}" ]] || rm -rf -- "${work_dir}"
	exit "${status}"
}

database() {
	docker exec -i "${postgres_container}" psql --no-psqlrc --username "${db_username}" \
		--dbname "${db_name}" --set=ON_ERROR_STOP=1 "$@"
}

header_value() {
	local name=$1
	local file=$2
	awk -v expected="${name}" '
		tolower($1) == tolower(expected ":") {
			sub(/^[^:]*:[[:space:]]*/, "")
			sub(/\r$/, "")
			print
			exit
		}
	' "${file}"
}

html_input_value() {
	local name=$1
	local file=$2
	sed -n "s/.*name=\"${name}\"[^>]*value=\"\([^\"]*\)\".*/\1/p" "${file}" | head -n 1
}

query_parameter() {
	local url=$1
	local name=$2
	local query="${url#*\?}"
	local pair
	[[ "${query}" != "${url}" ]] || return 1
	while [[ -n "${query}" ]]; do
		pair="${query%%&*}"
		if [[ "${pair%%=*}" == "${name}" ]]; then
			printf '%s\n' "${pair#*=}"
			return 0
		fi
		[[ "${query}" == *"&"* ]] || break
		query="${query#*&}"
	done
	return 1
}

decode_jwt_payload() {
	local token=$1
	local payload="${token#*.}"
	payload="${payload%%.*}"
	case $((${#payload} % 4)) in
		2) payload="${payload}==" ;;
		3) payload="${payload}=" ;;
		1) return 1 ;;
	esac
	printf '%s' "${payload}" | tr '_-' '/+' | openssl base64 -d -A
}

base32_to_hex() {
	awk '
		BEGIN { alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZ234567"; bits = "" }
		{
			for (i = 1; i <= length($0); i++) {
				value = index(alphabet, substr($0, i, 1)) - 1
				if (value < 0) exit 1
				for (bit = 4; bit >= 0; bit--) bits = bits int(value / (2 ^ bit)) % 2
			}
			while (length(bits) >= 8) {
				byte = substr(bits, 1, 8)
				bits = substr(bits, 9)
				value = 0
				for (i = 1; i <= 8; i++) value = value * 2 + substr(byte, i, 1)
				printf "%02x", value
			}
		}
		END { print "" }
	'
}

totp_code() {
	local secret=$1
	local timestep=$2
	local secret_hex counter_hex counter_bytes digest offset truncated
	secret_hex="$(printf '%s\n' "${secret}" | base32_to_hex)"
	[[ "${secret_hex}" =~ ^[0-9a-f]{40}$ ]] || fail "TOTP secret is not valid Base32"
	printf -v counter_hex '%016x' "${timestep}"
	counter_bytes="$(printf '%s' "${counter_hex}" | sed 's/../\\x&/g')"
	digest="$(printf '%b' "${counter_bytes}" \
		| openssl dgst -sha1 -mac HMAC -macopt "hexkey:${secret_hex}" -binary \
		| od -An -tx1 | tr -d ' \n')"
	[[ "${digest}" =~ ^[0-9a-f]{40}$ ]] || fail "Unable to calculate the TOTP digest"
	offset=$((16#${digest:39:1}))
	truncated=$((16#${digest:$((offset * 2)):8} & 0x7fffffff))
	printf '%06d\n' "$((truncated % 1000000))"
}

wait_for_stable_totp_window() {
	local elapsed
	elapsed="$(( $(date +%s) % 30 ))"
	if ((elapsed > 15)); then
		sleep "$((30 - elapsed))"
	fi
}

seed_fixture() {
	database --set=user_id="${USER_ID}" --set=client_id="${CLIENT_ID}" \
		--set=tenant_id="${TENANT_ID}" --set=username="${USERNAME}" \
		--set=encoded_password="${ENCODED_PASSWORD}" --set=client_identifier="${CLIENT_IDENTIFIER}" \
		--set=encoded_client_secret="${ENCODED_CLIENT_SECRET}" \
		--set=redirect_uri="${REDIRECT_URI}" >/dev/null <<'SQL'
BEGIN;
INSERT INTO users (user_id, tenant_id)
VALUES (:'user_id', :'tenant_id');
INSERT INTO user_login_identifiers
    (tenant_id, user_id, identifier_type, identifier_value, canonical_value)
VALUES
    (:'tenant_id', :'user_id', 'username', :'username', :'username');
INSERT INTO user_password_credentials (tenant_id, user_id, encoded_password)
VALUES (:'tenant_id', :'user_id', :'encoded_password');
INSERT INTO oauth_clients
    (client_id, tenant_id, client_identifier, display_name, client_type, authentication_method,
     encoded_client_secret, client_secret_issued_at, client_secret_expires_at,
     refresh_tokens_enabled, refresh_token_ttl_seconds)
VALUES
    (:'client_id', :'tenant_id', :'client_identifier', 'Release Check Admin Client',
     'confidential', 'client_secret_basic', :'encoded_client_secret', now(), now() + interval '90 days',
     TRUE, 3600);
INSERT INTO oauth_client_redirect_uris (tenant_id, client_id, redirect_uri)
VALUES (:'tenant_id', :'client_id', :'redirect_uri');
INSERT INTO oauth_client_scopes (tenant_id, client_id, scope)
VALUES (:'tenant_id', :'client_id', 'openid'), (:'tenant_id', :'client_id', 'iam.admin');
INSERT INTO admin_role_bindings (tenant_id, user_id, role_code, binding_type)
VALUES (:'tenant_id', :'user_id', 'super_admin', 'permanent');
COMMIT;
SQL
}

begin_authorization() {
	local cookies=$1
	local scopes=$2
	local state=$3
	local nonce=$4
	local code_challenge=$5
	local status location
	status="$(curl --silent --show-error --max-time 10 --output /dev/null --dump-header "${headers}" \
		--cookie-jar "${cookies}" --write-out '%{http_code}' --get "${base_url}/oauth2/authorize" \
		--header 'Accept: text/html' --data-urlencode 'response_type=code' \
		--data-urlencode "client_id=${CLIENT_IDENTIFIER}" --data-urlencode "redirect_uri=${REDIRECT_URI}" \
		--data-urlencode "scope=${scopes}" --data-urlencode "state=${state}" \
		--data-urlencode "nonce=${nonce}" --data-urlencode "code_challenge=${code_challenge}" \
		--data-urlencode 'code_challenge_method=S256')"
	[[ "${status}" == "302" ]] || fail "Authorization request returned HTTP ${status}"
	location="$(header_value Location "${headers}")"
	[[ "${location}" == */login ]] || fail "Authorization request did not redirect to login"
}

password_login() {
	local cookies=$1
	local status
	curl --fail --silent --show-error --max-time 10 --cookie "${cookies}" --cookie-jar "${cookies}" \
		--header 'Accept: text/html' --output "${body}" "${base_url}/login"
	csrf="$(html_input_value _csrf "${body}")"
	[[ -n "${csrf}" ]] || fail "Login page did not contain a CSRF token"
	status="$(curl --silent --show-error --max-time 10 --output /dev/null --dump-header "${headers}" \
		--cookie "${cookies}" --cookie-jar "${cookies}" --write-out '%{http_code}' --request POST \
		--data-urlencode "username=${USERNAME}" --data-urlencode "password=${PASSWORD}" \
		--data-urlencode "_csrf=${csrf}" "${base_url}/login")"
	[[ "${status}" == "302" ]] || fail "Password login returned HTTP ${status}"
}

account_csrf() {
	local cookies=$1
	local status
	status="$(curl --silent --show-error --max-time 10 --output "${body}" --write-out '%{http_code}' \
		--cookie "${cookies}" --cookie-jar "${cookies}" "${base_url}/iam/account/csrf")"
	[[ "${status}" == "200" ]] || fail "Account CSRF request returned HTTP ${status}"
	csrf_header="$(jq -er '.headerName' "${body}")"
	csrf="$(jq -er '.token' "${body}")"
	[[ -n "${csrf_header}" && -n "${csrf}" ]] || fail "Account CSRF response is incomplete"
}

trap cleanup EXIT
require_command curl
require_command docker
require_command jq
require_command openssl
require_command awk
require_command sed
require_command od
work_dir="$(mktemp -d "${TMPDIR:-/tmp}/iam-admin-mfa-smoke.XXXXXX")"
headers="${work_dir}/headers"
body="${work_dir}/body"
initial_cookies="${work_dir}/initial-cookies"
admin_cookies="${work_dir}/admin-cookies"
token_response="${work_dir}/token-response.json"
token_payload="${work_dir}/token-payload.json"
audit_export="${work_dir}/audit-events.ndjson"
code_challenge="$(printf '%s' "${CODE_VERIFIER}" | openssl dgst -sha256 -binary \
	| openssl base64 -A | tr '+/' '-_' | tr -d '=')"

log "Seeding disposable administrator and web client"
seed_fixture

log "Creating an authenticated account session"
begin_authorization "${initial_cookies}" 'openid' 'account-enrollment-state' \
	'account-enrollment-nonce' "${code_challenge}"
password_login "${initial_cookies}"
continuation="$(header_value Location "${headers}")"
[[ "${continuation}" == "${issuer}/oauth2/authorize?"* ]] \
	|| fail "Password login did not return to the authorization request"

log "Enrolling and activating a TOTP credential"
account_csrf "${initial_cookies}"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --dump-header "${headers}" \
	--write-out '%{http_code}' \
	--cookie "${initial_cookies}" --cookie-jar "${initial_cookies}" --request POST \
	--header "${csrf_header}: ${csrf}" "${base_url}/iam/account/mfa/totp/enrollments")"
[[ "${status}" == "201" ]] || fail "TOTP enrollment returned HTTP ${status}"
jq -e '.credentialId | test("^[0-9a-f-]{36}$")' "${body}" >/dev/null \
	|| fail "TOTP enrollment credential ID is invalid"
jq -e '.secret | test("^[A-Z2-7]{32}$")' "${body}" >/dev/null \
	|| fail "TOTP enrollment secret is invalid"
jq -e '.algorithm == "SHA1" and .digits == 6 and .periodSeconds == 30' "${body}" >/dev/null \
	|| fail "TOTP enrollment parameters are invalid"
jq -e '.expiresAt | type == "string" and test("Z$")' "${body}" >/dev/null \
	|| fail "TOTP enrollment expiry is invalid"
jq -e '.provisioningUri
	| startswith("otpauth://totp/") and contains("secret=") and contains("issuer=IAM")' \
	"${body}" >/dev/null || fail "TOTP provisioning URI is invalid"
credential_id="$(jq -er '.credentialId' "${body}")"
totp_secret="$(jq -er '.secret' "${body}")"
[[ "$(header_value Location "${headers}")" == "/iam/account/mfa/totp/enrollments/${credential_id}" ]] \
	|| fail "TOTP enrollment Location is invalid"
grep -Eiq '^cache-control:[[:space:]]*no-store([[:space:]]|,|$)' "${headers}" \
	|| fail "TOTP enrollment did not disable caching"
wait_for_stable_totp_window
activation_step="$(( $(date +%s) / 30 - 1 ))"
activation_code="$(totp_code "${totp_secret}" "${activation_step}")"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --write-out '%{http_code}' \
	--cookie "${initial_cookies}" --cookie-jar "${initial_cookies}" --request POST \
	--header "${csrf_header}: ${csrf}" --header 'Content-Type: application/json' \
	--data "$(jq -nc --arg code "${activation_code}" '{code:$code}')" \
	"${base_url}/iam/account/mfa/totp/enrollments/${credential_id}/activation")"
[[ "${status}" == "204" ]] || fail "TOTP activation returned HTTP ${status}"
active_totp_count="$(database --tuples-only --no-align --command \
	"SELECT count(*) FROM user_totp_credentials WHERE tenant_id = '${TENANT_ID}' AND user_id = '${USER_ID}' AND status = 'active'")"
[[ "${active_totp_count}" == "1" ]] || fail "TOTP activation did not persist one active credential"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --write-out '%{http_code}' \
	--cookie "${initial_cookies}" "${base_url}/iam/account/mfa")"
[[ "${status}" == "401" ]] || fail "TOTP activation left the old account session active"

log "Completing an Admin Authorization Code flow with TOTP"
admin_state="admin-mfa-state"
begin_authorization "${admin_cookies}" 'openid iam.admin' "${admin_state}" \
	'admin-mfa-nonce' "${code_challenge}"
password_login "${admin_cookies}"
password_location="$(header_value Location "${headers}")"
[[ "${password_location}" == "/login/mfa" || "${password_location}" == "${base_url}/login/mfa" ]] \
	|| fail "Admin password login did not require MFA; redirect was ${password_location:-missing}"
curl --fail --silent --show-error --max-time 10 --cookie "${admin_cookies}" --cookie-jar "${admin_cookies}" \
	--header 'Accept: text/html' --output "${body}" "${base_url}/login/mfa"
csrf="$(html_input_value _csrf "${body}")"
[[ -n "${csrf}" ]] || fail "MFA login page did not contain a CSRF token"
current_code="$(totp_code "${totp_secret}" "$(( $(date +%s) / 30 ))")"
status="$(curl --silent --show-error --max-time 10 --output /dev/null --dump-header "${headers}" \
	--cookie "${admin_cookies}" --cookie-jar "${admin_cookies}" --write-out '%{http_code}' --request POST \
	--data-urlencode 'factor=totp' --data-urlencode "code=${current_code}" \
	--data-urlencode "_csrf=${csrf}" "${base_url}/login/mfa")"
[[ "${status}" == "302" ]] || fail "TOTP login returned HTTP ${status}"
continuation="$(header_value Location "${headers}")"
[[ "${continuation}" == "${issuer}/oauth2/authorize?"* ]] \
	|| fail "TOTP login did not return to the authorization request"
continuation="${continuation#${issuer}}"
status="$(curl --silent --show-error --max-time 10 --cookie "${admin_cookies}" --cookie-jar "${admin_cookies}" \
	--header 'Accept: text/html' --output /dev/null --dump-header "${headers}" --write-out '%{http_code}' \
	"${base_url}${continuation}")"
[[ "${status}" == "302" ]] || fail "Admin authorization continuation returned HTTP ${status}"
consent_location="$(header_value Location "${headers}")"
[[ "${consent_location}" == "${issuer}/oauth2/consent?"* ]] \
	|| fail "Admin authorization did not reach consent"
consent_location="${consent_location#${issuer}}"
curl --fail --silent --show-error --max-time 10 --cookie "${admin_cookies}" --cookie-jar "${admin_cookies}" \
	--header 'Accept: text/html' --output "${body}" "${base_url}${consent_location}"
consent_state="$(html_input_value state "${body}")"
[[ -n "${consent_state}" ]] || fail "Admin consent page did not contain server state"
grep -q 'name="scope" value="iam.admin"' "${body}" || fail "Admin consent page did not request iam.admin"
status="$(curl --silent --show-error --max-time 10 --output /dev/null --dump-header "${headers}" \
	--cookie "${admin_cookies}" --cookie-jar "${admin_cookies}" --write-out '%{http_code}' --request POST \
	--data-urlencode "client_id=${CLIENT_IDENTIFIER}" --data-urlencode "state=${consent_state}" \
	--data-urlencode 'scope=iam.admin' "${base_url}/oauth2/authorize")"
[[ "${status}" == "302" ]] || fail "Admin consent submission returned HTTP ${status}"
client_redirect="$(header_value Location "${headers}")"
[[ "${client_redirect}" == "${REDIRECT_URI}?"* ]] || fail "Admin consent did not use the registered callback"
code="$(query_parameter "${client_redirect}" code)"
returned_state="$(query_parameter "${client_redirect}" state)"
[[ -n "${code}" && "${returned_state}" == "${admin_state}" ]] || fail "Admin authorization response is incomplete"
status="$(curl --silent --show-error --max-time 10 --output "${token_response}" --write-out '%{http_code}' \
	--user "${CLIENT_IDENTIFIER}:${CLIENT_SECRET}" --request POST --data-urlencode 'grant_type=authorization_code' \
	--data-urlencode "code=${code}" --data-urlencode "redirect_uri=${REDIRECT_URI}" \
	--data-urlencode "code_verifier=${CODE_VERIFIER}" "${base_url}/oauth2/token")"
[[ "${status}" == "200" ]] || fail "Admin token exchange returned HTTP ${status}"
admin_access_token="$(jq -er '.access_token' "${token_response}")"
decode_jwt_payload "${admin_access_token}" >"${token_payload}" \
	|| fail "Admin access-token payload is not valid base64url"
jq -e --arg audience "${admin_token_audience}" --arg user_id "${USER_ID}" --arg tenant_id "${TENANT_ID}" \
	'.sub == $user_id and .tenant_id == $tenant_id and .user_id == $user_id
	 and (.aud == $audience or .aud == [$audience]) and (.scope | index("iam.admin"))' \
	"${token_payload}" >/dev/null || fail "Admin access-token claims are invalid"

log "Checking Admin roles and audit APIs"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --write-out '%{http_code}' \
	--header "Authorization: Bearer ${admin_access_token}" "${base_url}/iam/admin/roles")"
[[ "${status}" == "200" ]] && jq -e '.roles | length > 0' "${body}" >/dev/null \
	|| fail "Admin role catalog response is invalid"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --write-out '%{http_code}' \
	--header "Authorization: Bearer ${admin_access_token}" "${base_url}/iam/admin/audit-events?limit=10")"
[[ "${status}" == "200" ]] && jq -e '.events | length > 0' "${body}" >/dev/null \
	|| fail "Admin audit event response is invalid"
export_from="$(database --tuples-only --no-align --command \
	"SELECT to_char(clock_timestamp() AT TIME ZONE 'UTC' - interval '1 hour', 'YYYY-MM-DD\"T\"HH24:MI:SS.US\"Z\"')")"
export_to="$(database --tuples-only --no-align --command \
	"SELECT to_char(clock_timestamp() AT TIME ZONE 'UTC', 'YYYY-MM-DD\"T\"HH24:MI:SS.US\"Z\"')")"
status="$(curl --silent --show-error --max-time 10 --output "${audit_export}" --write-out '%{http_code}' --get \
	--header 'Accept: application/x-ndjson' --header "Authorization: Bearer ${admin_access_token}" \
	--data-urlencode "from=${export_from}" --data-urlencode "to=${export_to}" --data-urlencode 'limit=1000' \
	"${base_url}/iam/admin/audit-events/export")"
[[ "${status}" == "200" ]] || fail "Admin audit export returned HTTP ${status}"
jq -se --arg user_id "${USER_ID}" \
	'length > 0 and all(.[]; (.id | type == "string") and (.type | type == "string"))
	 and any(.[]; .userId == $user_id)' "${audit_export}" >/dev/null \
	|| fail "Admin audit export is invalid"

log "Replacing recovery codes and checking live Admin-token invalidation"
account_csrf "${admin_cookies}"
status="$(curl --silent --show-error --max-time 20 --output "${body}" --write-out '%{http_code}' \
	--cookie "${admin_cookies}" --cookie-jar "${admin_cookies}" --request POST \
	--header "${csrf_header}: ${csrf}" "${base_url}/iam/account/mfa/recovery-codes")"
[[ "${status}" == "200" ]] || fail "Recovery-code replacement returned HTTP ${status}"
jq -e '.codes as $codes
	| ($codes | length == 10)
	  and all($codes[]; test("^[0-9A-HJKMNP-TV-Z]{5}(-[0-9A-HJKMNP-TV-Z]{5}){3}$"))' \
	"${body}" >/dev/null || fail "Recovery-code response is invalid"
status="$(curl --silent --show-error --max-time 10 --output "${body}" --dump-header "${headers}" \
	--write-out '%{http_code}' --header "Authorization: Bearer ${admin_access_token}" \
	"${base_url}/iam/admin/roles")"
[[ "${status}" == "401" ]] || fail "Recovery-code replacement left the Admin token active"
grep -Eiq '^www-authenticate:.*error="invalid_token"' "${headers}" \
	|| fail "Invalidated Admin token did not return an invalid_token challenge"

log "Admin MFA flow passed"
